---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
---

<Layout title="404 — Wiesn's bookshelf">
  <Header />
  <main class="main">
    <section class="section">
      <div class="section__inner">
        <p class="big-number">404</p>
        <h1 class="section__heading">你来到了没有信息的荒原</h1>
        <p class="section__desc">也许这里曾经有过什么，但现在已经不在了。</p>
        <div class="section__actions">
          <a href="/" class="btn">← 回家</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .section {
    display: flex;
    min-height: calc(100vh - 4rem);
    align-items: center;
    justify-content: center;
    padding-left: 1rem;
    padding-right: 1rem;
  }

  .section__inner {
    text-align: center;
  }

  .big-number {
    @apply font-plex-serif text-[6rem] font-medium leading-none text-offgray-200 dark:text-offgray-800 md:text-[8rem];
  }

  .section__heading {
    @apply mt-4 font-plex-serif text-xl font-medium tracking-wide text-offgray-950 dark:text-offgray-50;
  }

  .section__desc {
    @apply mt-2 text-sm tracking-tight text-offgray-500 dark:text-offgray-400;
  }

  .section__actions {
    margin-top: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .btn {
    @apply inline-flex items-center justify-center gap-1.5 h-9 px-4 rounded-sm text-sm font-medium tracking-tight border bg-accent-blue border-transparent text-white transition hover:bg-accent-blue-600 active:shadow-none disabled:opacity-50 disabled:cursor-not-allowed;
    box-shadow: hsl(219, 93%, 30%) 0 -2px 0 0 inset, hsl(219, 93%, 95%) 0 1px 3px 0;
  }

  .btn:hover {
    box-shadow: none;
  }

  @media (prefers-color-scheme: dark) {
    .btn {
      box-shadow: hsl(219, 93%, 30%) 0 -2px 0 0 inset, hsl(0, 0%, 0%, 0.4) 0 1px 3px 0;
    }
    .btn:hover {
      box-shadow: none;
    }
  }
</style>
