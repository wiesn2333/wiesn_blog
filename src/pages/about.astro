---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import SnsLinks from "../components/SnsLinks.astro";
---

<Layout title="About — Wiesn's bookshelf">
  <Header />
  <main class="main">
    <Hero title="关于维森" description="一个在键盘和书本之间迷路的人" />

    <section class="section">
      <div class="section__inner">
        <div class="card">
          <p class="card__text">废物大学生，啥都不会，一事无成</p>
          <p class="card__emoji">😭</p>
          <div class="card__sns">
            <SnsLinks />
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .section {
    padding-left: 1rem;
    padding-right: 1rem;
    padding-bottom: 3rem;
  }

  @media (min-width: 1024px) {
    .section {
      padding-bottom: 4rem;
    }
  }

  .section__inner {
    @apply mx-auto max-w-lg px-4;
  }

  .card {
    @apply rounded-sm border p-8 bg-cream-50/60 dark:bg-offgray-900;
    @apply border-offgray-200/60 dark:border-gray-500/30;
    box-shadow: hsl(218, 13%, 50%, 0.05) 0 -2px 0 0 inset;
  }

  @media (prefers-color-scheme: dark) {
    .card {
      box-shadow: hsl(218, 13%, 40%, 0.05) 0 -2px 0 0 inset;
    }
  }

  .card__text {
    @apply text-center tracking-tight text-offgray-600 dark:text-offgray-400;
  }

  .card__emoji {
    @apply mt-4 text-center text-lg text-offgray-400 dark:text-offgray-500;
  }

  .card__sns {
    @apply mt-6 flex justify-center;
  }
</style>
